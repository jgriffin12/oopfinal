@startuml
title 04 - Development / Package View

skinparam packageStyle rectangle

package "frontend/" {
  [index.html]
  [style.css]
  [script.js]
}

package "apps/" {
  [main.py]

  package "routes/" {
    [authRoutes.py]
    [recordroutes.py]
    [adminroutes.py]
  }

  package "controllers/" {
    [AuthController]
  }

  package "services/" {
    [AuthService]
    [MFAService]
    [RecordService]
    [AccessControlService]
    [AuditLogger]
  }

  package "security/" {
    [PasswordHasher]
    [MFAFactory]
    [MFAStrategy]
    [EmailMFAStrategy]
    [SensitiveDataMasker]
    [Tokenizer]
  }

  package "repositories/" {
    [UserRepository]
    [RecordRepository]
    [AuditRepository]
  }

  package "models/" {
    [User]
    [MedicalRecord]
    [SecurityEvent]
  }
}

package "tests/" {
  [Unit Tests]
  [Property-Based Tests]
}

package "Docs/Uml/" {
  [UML Diagrams]
}

[index.html] --> [script.js]
[script.js] --> [authRoutes.py] : API calls
[script.js] --> [recordroutes.py] : API calls
[script.js] --> [adminroutes.py] : API calls

[main.py] --> [authRoutes.py]
[main.py] --> [recordroutes.py]
[main.py] --> [adminroutes.py]

[authRoutes.py] --> [AuthController]
[AuthController] --> [AuthService]

[recordroutes.py] --> [RecordService]
[adminroutes.py] --> [AuditLogger]

[AuthService] --> [UserRepository]
[AuthService] --> [PasswordHasher]
[AuthService] --> [MFAService]
[AuthService] --> [AuditLogger]

[MFAService] --> [MFAFactory]
[MFAFactory] --> [MFAStrategy]
[MFAStrategy] <|.. [EmailMFAStrategy]

[RecordService] --> [RecordRepository]
[RecordService] --> [AccessControlService]
[RecordService] --> [SensitiveDataMasker]
[RecordService] --> [Tokenizer]
[RecordService] --> [AuditLogger]

[AuditLogger] --> [AuditRepository]

[UserRepository] --> [User]
[RecordRepository] --> [MedicalRecord]
[AuditRepository] --> [SecurityEvent]

[Unit Tests] --> [services/]
[Unit Tests] --> [security/]
[Property-Based Tests] --> [security/]

@enduml